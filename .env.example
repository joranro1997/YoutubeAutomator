# Copy to .env and fill in. Never commit .env.

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...

# --- YouTube Data API v3 ---
# OAuth client credentials file path (downloaded from Google Cloud Console)
YOUTUBE_CLIENT_SECRETS_PATH=./secrets/client_secret.json
# Token cache (auto-generated on first auth)
YOUTUBE_TOKEN_PATH=./secrets/youtube_token.json
YOUTUBE_CHANNEL_ID=

# --- Reddit (read-only, via PRAW) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=YoutubeAutomator/0.1 by u/yourusername

# --- Discord (real bot in user's own server, ToS-safe) ---
# Bot reads from "Follow"-mirrored channels in the user's own server.
# Create at https://discord.com/developers/applications -> New Application
# -> Bot tab -> Reset Token. Required scopes: bot. Required permission:
# View Channel + Read Message History. NEVER commit this token.
DISCORD_BOT_TOKEN=

# --- Paths (override per-machine) ---
# On Mac (dev): leave blank, defaults resolve relative to repo
# On Windows (runtime): point to your shared assets folder
ASSETS_ROOT=
PREMIERE_TEMPLATES_DIR=
PHOTOSHOP_TEMPLATES_DIR=
